{
  "name": "claude-evergreen-proxy",
  "version": "1.1.0",
  "description": "Use your Claude Max subscription with any OpenAI-compatible client. Wraps Claude Code CLI as an OpenAI-compatible API server with a self-updating model registry (no manual model maintenance).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-evergreen": "dist/server/standalone.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/standalone.js",
    "test": "node --test dist/unit.test.js",
    "test:e2e": "node --test dist/e2e.test.js",
    "test:all": "node --test dist/unit.test.js dist/e2e.test.js",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "claude-max",
    "openai-compatible",
    "api-server",
    "oauth",
    "clawdbot",
    "llm",
    "ai"
  ],
  "author": "Manny Lee <softweaver@naver.com>",
  "contributors": [
    "Atal Ashutosh (original claude-max-api-proxy)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ngenieer/claude-evergreen-proxy"
  },
  "bugs": {
    "url": "https://github.com/ngenieer/claude-evergreen-proxy/issues"
  },
  "homepage": "https://github.com/ngenieer/claude-evergreen-proxy#readme",
  "dependencies": {
    "express": "^4.21.2",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "clawdbot": ">=2026.1.0"
  },
  "peerDependenciesMeta": {
    "clawdbot": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CONTRIBUTING.md"
  ]
}
